# === Infrastructure (docker-compose) ===
# Most Langfuse infra vars have defaults in docker-compose.yaml.
# Only override here if you need non-default values.
# For production: generate LANGFUSE_ENCRYPTION_KEY with `openssl rand -hex 32`

DB_PASSWORD=dbpassword9090
LITELLM_MASTER_KEY=sk-1234

# === Application (host-side, used by src/main.py) ===

# LiteLLM proxy port (default 30000)
LITELLM_PORT=30000

# LiteLLM config (path to config.yaml with model list)
CONFIG_FILE_PATH=src/config.yaml

# Database — LiteLLM UI and user management require this
DATABASE_URL=postgresql://llmproxy:dbpassword9090@localhost:30432/litellm
DB_HOST=localhost
DB_PORT=30432
DB_NAME=litellm
DB_USER=llmproxy
DB_PASSWORD=dbpassword9090

# Langfuse — DEV instance on port 33000 (NOT the host instance on :3000)
# LANGFUSE_HOST is read by the Langfuse SDK directly (used by LiteLLM callback)
# LANGFUSE_API_HOST is read by our Settings class (used by the scraper)
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_HOST=http://localhost:33000
LANGFUSE_API_HOST=http://localhost:33000

# OpenRouter
# OPENROUTER_API_KEY — used by LiteLLM config.yaml for model routing
# API_KEY / API_BASE_URL — used by src/middleware.py for the judge model classifier
# These are the same key, listed separately because they're consumed by different components
OPENROUTER_API_KEY=sk-or-...
API_BASE_URL=https://openrouter.ai/api/v1
API_KEY=sk-or-...
